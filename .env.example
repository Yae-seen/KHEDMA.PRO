# Khedma Pro — environment variables. Copy to .env.local and fill in.
# Everything is OPTIONAL: unset vars simply disable that integration.

# --- Analytics -------------------------------------------------------------
# GA4 is LIVE via a committed default (G-NQFV0NQGXH) in site-analytics.tsx +
# next.config.ts — no env needed. Set these only to OVERRIDE (e.g. a new property).
# Google Analytics 4 measurement ID (direct gtag). Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Optional Google Tag Manager CONTAINER (only a GTM-XXXXXXX id — NOT a GT- Google
# tag; the site's GT- tag already routes to the GA4 property above via gtag.js).
NEXT_PUBLIC_GTM_ID=
# Vercel Analytics + Speed Insights need no keys — they auto-enable on Vercel.

# --- Supabase backend (auth + job board + saved jobs) ----------------------
# Create a project at supabase.com, then paste the Project URL and anon key.
# Without these, the site runs exactly as before (no account UI, no live board).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, never expose to the client. Used by admin
# scripts / server actions that seed or moderate jobs.
SUPABASE_SERVICE_ROLE_KEY=

# --- IndexNow --------------------------------------------------------------
# Key is committed as public/91f18365b37142a2b97cbc79171e5447.txt and hard-coded
# in scripts/indexnow.mjs. Run `node scripts/indexnow.mjs` after deploy.
